---
const scores = [
  { label: 'Performance',      value: 100 },
  { label: 'Acessibilidade',   value: 100 },
  { label: 'Melhores Práticas', value: 100 },
];

const psiUrl = 'https://pagespeed.web.dev/report?url=https%3A%2F%2Fmarujos.dev';

// SVG ring math: r=40, cx=50, cy=50 → circumference ≈ 251.3
const R = 40;
const CIRC = +(2 * Math.PI * R).toFixed(2);
---

<section id="psi-badge" class="mx-auto max-w-6xl px-6 pb-24">
  <a
    href={psiUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="group flex flex-col items-center gap-8 rounded-2xl border border-slate-800 bg-slate-900/40 px-8 py-10 backdrop-blur-sm transition-all duration-500 hover:border-emerald-500/30 hover:bg-slate-900/60 hover:shadow-[0_0_48px_-16px_rgba(52,211,153,0.25)] sm:flex-row sm:justify-between"
  >
    <!-- left: label -->
    <div class="flex flex-col gap-1 text-center sm:text-left">
      <div class="flex items-center justify-center gap-2 sm:justify-start">
        <!-- PageSpeed G icon -->
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" fill="#4CAF50"/>
          <path d="M12 6v6l4 2-1 1.73-4.87-2.81A1 1 0 0 1 9 12V6h3z" fill="white"/>
        </svg>
        <span class="text-xs font-semibold uppercase tracking-widest text-emerald-400">
          Google PageSpeed Insights
        </span>
      </div>
      <p class="text-xl font-bold text-white">marujos.dev</p>
      <p class="text-sm text-slate-400">
        Pontuação verificável em tempo real →
      </p>
    </div>

    <!-- right: score circles — aria-hidden: decorativos, o texto do link já descreve o destino -->
    <div class="flex items-center gap-8 sm:gap-10" aria-hidden="true">
      {scores.map((s) => {
        const offset = +(CIRC * (1 - s.value / 100)).toFixed(2);
        return (
          <div class="psi-score flex flex-col items-center gap-3">
            <div class="relative h-20 w-20">
              <svg viewBox="0 0 100 100" class="h-full w-full -rotate-90" aria-hidden="true">
                <!-- track -->
                <circle
                  cx="50" cy="50" r={R}
                  fill="none"
                  stroke="currentColor"
                  stroke-width="8"
                  class="text-slate-800"
                />
                <!-- progress ring -->
                <circle
                  cx="50" cy="50" r={R}
                  fill="none"
                  stroke="currentColor"
                  stroke-width="8"
                  stroke-linecap="round"
                  stroke-dasharray={CIRC}
                  stroke-dashoffset={offset}
                  class="psi-ring text-emerald-400 transition-all duration-1000"
                />
              </svg>
              <!-- score number -->
              <span class="absolute inset-0 flex items-center justify-center text-xl font-bold text-white">
                {s.value}
              </span>
            </div>
            <span class="text-center text-xs font-medium text-slate-400">{s.label}</span>
          </div>
        );
      })}
    </div>
  </a>
</section>

<script>
  const section = document.getElementById('psi-badge');
  const badge = document.querySelector<HTMLElement>('#psi-badge > a');
  const rings = document.querySelectorAll<SVGCircleElement>('.psi-ring');

  // Estado inicial — os elementos ficam abaixo da dobra quando este script roda,
  // então podem ser ocultados antes do browser pintar a região visível ao usuário.
  if (badge) {
    badge.style.opacity = '0';
    badge.style.transform = 'translateY(24px)';
  }
  rings.forEach(ring => {
    const totalDash = parseFloat(ring.getAttribute('stroke-dasharray') ?? '251.33');
    ring.style.strokeDashoffset = String(totalDash);
  });

  const showBadge = () => {
    if (badge) {
      badge.style.transition = 'opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1)';
      badge.style.opacity = '1';
      badge.style.transform = 'translateY(0)';
    }
    rings.forEach(ring => {
      ring.style.transition = 'stroke-dashoffset 1.2s cubic-bezier(0.16,1,0.3,1) 0.3s';
      ring.style.strokeDashoffset = ring.getAttribute('stroke-dashoffset') ?? '0';
    });
  };

  if (section) {
    const io = new IntersectionObserver((entries) => {
      if (!entries[0].isIntersecting) return;
      io.disconnect();
      showBadge();
    }, { rootMargin: '0px 0px -10% 0px' });

    io.observe(section);

    // Fallback: garante visibilidade após 2.5s caso o observer não dispare
    setTimeout(() => {
      if (badge && parseFloat(getComputedStyle(badge).opacity) < 0.5) showBadge();
    }, 2500);
  }
</script>
