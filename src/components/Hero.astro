---
const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/flaviofilipe',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
    </svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/flaviofilipedev',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>`,
  },
  {
    label: 'Dev.to',
    href: 'https://dev.to/marujosx',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6l.02 2.44.04 2.45.56-.02c.41 0 .63-.07.83-.26.24-.24.26-.36.26-2.2 0-1.91-.02-1.96-.29-2.18zM0 4.94v14.12h24V4.94H0zM8.56 15.3c-.44.58-1.06.77-2.53.77H4.71V8.53h1.4c1.67 0 2.16.18 2.6.9.27.43.29.6.32 2.57.05 2.23-.02 2.73-.47 3.3zm5.09-5.47h-2.47v1.77h1.52v1.28l-.72.04-.75.03v1.77l1.22.03 1.2.04v1.28h-1.6c-1.53 0-1.6-.01-1.87-.3l-.3-.28v-3.16c0-3.02.01-3.18.25-3.48.23-.31.25-.31 1.88-.31h1.64v1.29zm4.68 5.45c-.17.43-.64.79-1 .79-.18 0-.45-.15-.67-.39-.32-.32-.45-.63-.82-2.08l-.9-3.39-.45-1.67h.76c.4 0 .75.02.75.05 0 .06 1.16 4.54 1.26 4.83.04.15.32-.7.73-2.3l.66-2.52.74-.04c.4-.02.73 0 .73.04 0 .14-1.67 6.38-1.8 6.68z"/>
    </svg>`,
  },
  {
    label: 'Medium',
    href: 'https://medium.com/marujosx',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/>
    </svg>`,
  },
];
---

<section
  id="hero"
  class="relative flex min-h-screen items-center overflow-hidden px-6 py-24"
>
  <!-- background glow orbs -->
  <div class="pointer-events-none absolute left-1/4 top-1/2 -z-10 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-violet-700/10 blur-[120px]"></div>
  <div class="pointer-events-none absolute right-1/4 top-1/3 -z-10 h-[400px] w-[400px] -translate-y-1/2 rounded-full bg-cyan-500/8 blur-[100px]"></div>

  <div class="mx-auto grid w-full max-w-7xl grid-cols-1 items-center gap-12 md:grid-cols-2">

    <!-- col esquerda: texto -->
    <div class="flex flex-col items-center text-center md:items-start md:text-left">

      <!-- badge -->
      <div id="hero-badge" class="mb-8 inline-flex items-center gap-2 rounded-full border border-slate-700/60 bg-slate-800/50 px-4 py-1.5 text-xs font-medium tracking-widest text-slate-400 uppercase backdrop-blur-sm">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
        Disponível para novos projetos
      </div>

      <!-- headline -->
      <h1 id="hero-headline" class="mb-6 text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl xl:text-6xl">
        Engenharia de software de
        <span class="bg-gradient-to-r from-violet-400 via-fuchsia-400 to-cyan-400 bg-clip-text text-transparent">{' '}alta performance{' '}</span>
        para produtos digitais excepcionais.
      </h1>

      <!-- subheadline -->
      <p id="hero-sub" class="mb-10 max-w-lg text-lg leading-relaxed text-slate-400">
        Desenvolvimento focado em arquitetura serverless,
        otimização de dados e experiências web de alto impacto.
      </p>

      <!-- CTA button -->
      <div id="hero-cta" class="mb-12 flex flex-col items-center gap-3 md:items-start">
        <!-- FAKE — substituir pelo link real de agendamento -->
        <a
          href="https://calendly.com/marujos/consultoria"
          target="_blank"
          rel="noopener noreferrer"
          class="group relative inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-violet-600 to-cyan-500 px-8 py-3.5 text-sm font-semibold text-white shadow-lg transition-all duration-300 hover:from-violet-500 hover:to-cyan-400 hover:shadow-[0_0_32px_-4px_rgba(139,92,246,0.6)] focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2 focus:ring-offset-slate-950"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Agendar uma conversa gratuita
          <span class="absolute inset-0 rounded-full ring-1 ring-inset ring-white/10 transition-opacity duration-300 group-hover:ring-white/20"></span>
        </a>
        <a
          href="mailto:flaviofilipe.dev@gmail.com?subject=Orçamento%20%2F%20Contato%20—%20Marujos"
          class="text-sm text-slate-500 transition-colors duration-200 hover:text-slate-300"
        >
          ou mande um e-mail →
        </a>
      </div>

      <!-- social links -->
      <div id="hero-socials" class="flex items-center justify-center gap-6 md:justify-start">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={link.label}
            class="flex items-center justify-center text-slate-500 transition-colors duration-200 hover:text-slate-200"
          >
            <Fragment set:html={link.icon} />
          </a>
        ))}
      </div>
    </div>

    <!-- col direita: visual decorativo CSS-only (zero JS, zero LCP impact) -->
    <div
      class="relative hidden h-[460px] w-full md:flex md:items-center md:justify-center lg:h-[540px]"
      aria-hidden="true"
    >
      <!-- anéis giratórios — nenhum é candidato LCP (border CSS puro) -->
      <span class="absolute h-[320px] w-[320px] animate-spin rounded-full border border-cyan-400/15 border-t-cyan-400/70 [animation-duration:14s] [animation-timing-function:linear]"></span>
      <span class="absolute h-[240px] w-[240px] animate-spin rounded-full border border-violet-400/15 border-b-violet-500/70 [animation-direction:reverse] [animation-duration:9s] [animation-timing-function:linear]"></span>
      <span class="absolute h-[160px] w-[160px] animate-spin rounded-full border border-fuchsia-400/15 border-t-fuchsia-400/70 [animation-duration:5.5s] [animation-timing-function:linear]"></span>
      <span class="absolute h-[80px] w-[80px] animate-spin rounded-full border border-cyan-300/20 border-r-cyan-300/80 [animation-duration:2.5s] [animation-timing-function:linear]"></span>
      <!-- marcadores nos anéis externos -->
      <span class="absolute h-[320px] w-[320px] animate-spin rounded-full [animation-duration:14s] [animation-timing-function:linear]">
        <span class="absolute left-1/2 top-0 h-1.5 w-1.5 -translate-x-1/2 -translate-y-1/2 rounded-full bg-cyan-400/70"></span>
      </span>
      <span class="absolute h-[240px] w-[240px] animate-spin rounded-full [animation-direction:reverse] [animation-duration:9s] [animation-timing-function:linear]">
        <span class="absolute bottom-0 left-1/2 h-1 w-1 -translate-x-1/2 translate-y-1/2 rounded-full bg-violet-400/70"></span>
      </span>
      <!-- brilho ambiente -->
      <div class="absolute h-[220px] w-[220px] rounded-full bg-cyan-500/5 blur-3xl"></div>
      <div class="absolute h-[120px] w-[120px] rounded-full bg-violet-600/8 blur-2xl"></div>
      <!-- ponto central -->
      <div class="h-3 w-3 rounded-full bg-cyan-400 shadow-[0_0_24px_6px_rgba(34,211,238,0.35)]"></div>
    </div>

  </div>
</section>

<style>
  /* Usada por badge, sub, cta e socials — esconde antes de animar */
  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /*
   * O headline nunca fica invisible (sem fade de opacidade).
   * Isso garante que o browser capture o LCP no primeiro paint (~0.4 s)
   * em vez de esperar a animação completar (~1.4 s com fill-mode backwards).
   */
  @keyframes hero-slide-up {
    from { transform: translateY(16px); }
    to   { transform: translateY(0); }
  }

  #hero-badge    { animation: hero-fade-up  0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both; }
  #hero-headline { animation: hero-slide-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s  both; }
  #hero-sub      { animation: hero-fade-up  0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.40s both; }
  #hero-cta      { animation: hero-fade-up  0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.55s both; }

  #hero-socials a:nth-child(1) { animation: hero-fade-up 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.65s both; }
  #hero-socials a:nth-child(2) { animation: hero-fade-up 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.73s both; }
  #hero-socials a:nth-child(3) { animation: hero-fade-up 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.81s both; }
  #hero-socials a:nth-child(4) { animation: hero-fade-up 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.89s both; }
</style>
