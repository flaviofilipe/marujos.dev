---
import { stack } from '../../data/stack';

const categories = [
  "Linguagens & Frameworks",
  "Dados & Observabilidade",
  "Cloud & DevOps",
] as const;

const grouped = Object.fromEntries(
  categories.map((cat) => [cat, stack.filter((s) => s.category === cat)])
) as Record<string, typeof stack>;
---

<section id="stack" class="mx-auto max-w-6xl px-6 py-24">

  <div data-animate="reveal" class="mb-14 text-center">
    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-slate-400">
      Stack &amp; Ferramentas
    </p>
    <h2 class="text-3xl font-bold text-white sm:text-4xl">
      Tecnologias que aplicamos em{' '}
      <span class="bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-transparent">
        consultoria e entrega
      </span>
    </h2>
  </div>

  <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
    {categories.map((cat) => (
      <div data-animate="reveal" class="flex flex-col gap-4">

        <!-- Subtítulo da categoria -->
        <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-500">
          {cat}
        </h3>

        <!-- Badges -->
        <div class="flex flex-wrap gap-2">
          {grouped[cat].map((item) => (
            <span class="inline-flex items-center rounded-full border border-white/[0.06] bg-white/[0.03] px-3 py-1 text-sm font-medium text-slate-300 transition-colors duration-200 hover:border-white/10 hover:bg-white/[0.05] hover:text-white">
              {item.name}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
