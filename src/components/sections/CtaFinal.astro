---
// FAKE — substituir pelo link real de agendamento
const calendlyUrl = 'https://calendly.com/marujos/consultoria';
const mailtoUrl   = 'mailto:flaviofilipe.dev@gmail.com?subject=Contato%20%E2%80%94%20Marujos';
---

<section id="contato" class="mx-auto max-w-6xl px-6 py-24">

  <div
    data-animate="reveal"
    class="relative overflow-hidden rounded-3xl border border-white/[0.06] bg-gradient-to-br from-violet-950/40 via-slate-900/60 to-cyan-950/30 px-8 py-16 text-center backdrop-blur-sm sm:px-16"
  >
    <!-- Orbs decorativos -->
    <div class="pointer-events-none absolute left-1/4 top-0 -z-0 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full bg-violet-600/10 blur-3xl" aria-hidden="true"></div>
    <div class="pointer-events-none absolute bottom-0 right-1/4 -z-0 h-64 w-64 translate-x-1/2 translate-y-1/2 rounded-full bg-cyan-600/10 blur-3xl" aria-hidden="true"></div>

    <div class="relative z-10">
      <p class="mb-4 text-xs font-medium uppercase tracking-widest text-slate-400">
        Pronto para o próximo passo?
      </p>
      <h2 class="mb-4 text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
        Vamos construir{' '}
        <span class="bg-gradient-to-r from-violet-400 via-fuchsia-400 to-cyan-400 bg-clip-text text-transparent">
          juntos
        </span>
      </h2>
      <p class="mx-auto mb-10 max-w-lg text-base text-slate-400">
        Agende uma conversa gratuita de 30 minutos e descubra como a Marujos pode acelerar seu produto.
      </p>

      <div class="flex flex-col items-center gap-4">
        <!-- Botão primário: Calendly -->
        <a
          href={calendlyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-violet-600 to-cyan-500 px-8 py-3.5 text-sm font-semibold text-white shadow-lg transition-all duration-300 hover:from-violet-500 hover:to-cyan-400 hover:shadow-[0_0_40px_-4px_rgba(139,92,246,0.6)] focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2 focus:ring-offset-slate-950"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Agendar conversa gratuita
        </a>

        <!-- Botão secundário: e-mail -->
        <a
          href={mailtoUrl}
          class="text-sm text-slate-500 underline-offset-4 transition-colors duration-200 hover:text-slate-300 hover:underline"
        >
          ou mande um e-mail →
        </a>
      </div>
    </div>
  </div>
</section>
