---
import { testimonials } from '../../data/testimonials';
---

<section id="depoimentos" class="mx-auto max-w-6xl px-6 py-24">

  <div data-animate="reveal" class="mb-14 text-center">
    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-slate-400">
      O que dizem sobre nós
    </p>
    <h2 class="text-3xl font-bold text-white sm:text-4xl">
      Resultado que{' '}
      <span class="bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-transparent">
        fala por si
      </span>
    </h2>
  </div>

  <!--
    Mobile: scroll horizontal com snap
    Desktop: grid 3 colunas
  -->
  <div
    data-animate="stagger-group"
    class="flex snap-x snap-mandatory gap-5 overflow-x-auto pb-4 sm:grid sm:grid-cols-3 sm:overflow-visible sm:pb-0"
    style="scrollbar-width: none;"
  >
    {testimonials.map((t) => (
      <div class="flex w-[80vw] shrink-0 snap-start flex-col gap-5 rounded-2xl border border-white/[0.06] bg-white/[0.02] p-7 sm:w-auto">

        <!-- Aspas decorativas -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="text-violet-500/40"
          aria-hidden="true"
        >
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
        </svg>

        <!-- Quote -->
        <blockquote class="flex-1 text-sm leading-relaxed text-slate-300">
          "{t.quote}"
        </blockquote>

        <!-- Autor -->
        <div class="flex items-center gap-3">
          <img
            src={t.photo}
            alt={`Foto de ${t.name}`}
            width="40"
            height="40"
            class="h-10 w-10 rounded-full object-cover ring-1 ring-white/10"
            loading="lazy"
          />
          <div>
            <p class="text-sm font-semibold text-white">{t.name}</p>
            <p class="text-xs text-slate-500">{t.role} · {t.company}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
