---
const projects = [
  {
    name: "Ginga",
    description: "Plataforma SaaS construída internamente para gerenciar e automatizar processos operacionais. Desenvolvida com Django e Python, containerizada com Docker e interface moderna em Tailwind CSS.",
    tags: ["Python", "Django", "Docker", "Tailwind"],
    href: "https://ginga.marujos.dev",
    label: "ginga.marujos.dev",
    status: "Em produção",
    accent: "violet",
    icon: `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>`,
  },
  {
    name: "Pet Control",
    description: "Ecossistema para bem-estar animal: histórico de saúde, vacinas, tratamentos e rotinas, com foco em experiência do usuário e regras de negócio claras.",
    tags: ["TypeScript", "Python", "FastAPI"],
    href: "https://pet-control.marujos.dev/",
    label: "pet-control.marujos.dev",
    status: "Em produção",
    accent: "cyan",
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  },
  {
    name: "GruPy-VCA",
    description: "Comunidade oficial de Python em Vitória da Conquista: eventos, mentoria, automação e integração com o ecossistema local de inovação.",
    tags: ["Python", "Github Pages", "Comunidade"],
    href: "https://grupy-vca.github.io/",
    label: "grupy-vca.github.io",
    status: "Comunidade",
    accent: "emerald",
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  },
] as const;

const accentMap = {
  violet:  { border: "hover:border-violet-500/40", glow: "hover:shadow-[0_0_40px_-12px_rgba(139,92,246,0.25)]", icon: "bg-violet-500/10 text-violet-400", tag: "bg-violet-500/10 text-violet-400 ring-violet-500/20", link: "text-violet-400", status: "bg-violet-500/10 text-violet-400 ring-violet-500/20" },
  cyan:    { border: "hover:border-cyan-500/40",   glow: "hover:shadow-[0_0_40px_-12px_rgba(34,211,238,0.25)]",  icon: "bg-cyan-500/10 text-cyan-400",   tag: "bg-cyan-500/10 text-cyan-400 ring-cyan-500/20",   link: "text-cyan-400",   status: "bg-cyan-500/10 text-cyan-400 ring-cyan-500/20"   },
  emerald: { border: "hover:border-emerald-500/40",glow: "hover:shadow-[0_0_40px_-12px_rgba(52,211,153,0.25)]", icon: "bg-emerald-500/10 text-emerald-400",tag: "bg-emerald-500/10 text-emerald-400 ring-emerald-500/20",link: "text-emerald-400",status: "bg-emerald-500/10 text-emerald-400 ring-emerald-500/20" },
};
---

<section id="projetos" class="mx-auto max-w-6xl px-6 py-24">

  <div data-animate="reveal" class="mb-14 text-center">
    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-slate-400">
      Projetos &amp; Iniciativas
    </p>
    <h2 class="text-3xl font-bold text-white sm:text-4xl">
      Onde colocamos a{' '}
      <span class="bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-transparent">
        mão na massa
      </span>
    </h2>
  </div>

  <div data-animate="stagger-group" class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
    {projects.map((project) => {
      const a = accentMap[project.accent];
      return (
        <div class={`group relative flex flex-col gap-5 rounded-2xl border border-slate-800 bg-slate-900/60 p-8 backdrop-blur-sm transition-all duration-300 ${a.border} ${a.glow}`}>

          <div class="flex items-start justify-between">
            <div class="flex items-center gap-3">
              <div class={`flex h-10 w-10 items-center justify-center rounded-xl ${a.icon}`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <Fragment set:html={project.icon} />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white">{project.name}</h3>
            </div>
            <span class={`shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset ${a.status}`}>
              {project.status}
            </span>
          </div>

          <p class="flex-1 text-sm leading-relaxed text-slate-400">
            {project.description}
          </p>

          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset ${a.tag}`}>
                {tag}
              </span>
            ))}
          </div>

          <a
            href={project.href}
            target="_blank"
            rel="noopener noreferrer"
            class={`inline-flex items-center gap-1.5 text-sm font-semibold transition-opacity duration-200 hover:opacity-75 ${a.link}`}
          >
            {project.label}
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
            </svg>
          </a>
        </div>
      );
    })}
  </div>
</section>
