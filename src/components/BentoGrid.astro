---
const cards = [
  {
    id: 'bento-perf',
    title: 'Performance e Escala',
    accent: 'emerald',
    span: 'md:col-span-2',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    description: 'Substituição de stacks legadas (WordPress/PHP monolítico) por arquiteturas modernas com Next.js e Astro que entregam carregamentos sub-segundo. Especialidade em otimização de consultas SQL pesadas, cache em camadas e processamento assíncrono de dados.',
    tags: ['Next.js', 'Astro', 'PostgreSQL', 'Redis', 'DataDog'],
    highlight: 'Redução de até 90% no TTFB vs. stacks legadas.',
  },
  {
    id: 'bento-cloud',
    title: 'Serverless & Cloud',
    accent: 'cyan',
    span: 'md:col-span-1',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>`,
    description: 'Arquiteturas event-driven com AWS Lambda, SQS e API Gateway que escalam de zero a milhões de requisições sem provisionamento manual. Custo de infraestrutura proporcional ao uso real.',
    tags: ['AWS Lambda', 'SQS', 'SNS', 'Serverless Framework', 'Python'],
    highlight: 'Custo de infra próximo de zero em baixa demanda.',
  },
  {
    id: 'bento-marujos',
    title: 'O Coletivo Marujos',
    accent: 'violet',
    span: 'md:col-span-1',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    description: 'Publicação de tecnologia no Medium focada em compartilhar conhecimento prático de engenharia de software, arquitetura de sistemas e cultura ágil.',
    tags: ['Engenharia', 'Arquitetura', 'DevOps', 'Cultura Ágil'],
    highlight: null,
    link: { href: 'https://medium.com/marujosx', label: 'Ler no Medium →' },
  },
  {
    id: 'bento-ai',
    title: 'Validação por IA: Performance & Segurança',
    accent: 'fuchsia',
    span: 'md:col-span-2',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
    description: 'Utilizamos ferramentas de IA para auditar pipelines de dados em tempo real — identificando gargalos de performance, anomalias de acesso e vetores de exposição antes que cheguem à produção. A análise cobre desde queries lentas e consumo de memória até conformidade com políticas de segurança e controle de acesso a dados sensíveis.',
    tags: ['Auditoria de Dados', 'Detecção de Anomalias', 'LGPD / Compliance', 'DataDog', 'LLM'],
    highlight: 'Falhas de segurança e gargalos detectados antes de irem para produção.',
  },
];

const accentMap: Record<string, { border: string; icon: string; tag: string; glow: string; highlight: string }> = {
  emerald: {
    border: 'hover:border-emerald-500/40',
    icon: 'text-emerald-400',
    tag: 'bg-emerald-500/10 text-emerald-400 ring-emerald-500/20',
    glow: 'group-hover:shadow-[0_0_40px_-12px_rgba(52,211,153,0.3)]',
    highlight: 'text-emerald-400',
  },
  cyan: {
    border: 'hover:border-cyan-500/40',
    icon: 'text-cyan-400',
    tag: 'bg-cyan-500/10 text-cyan-400 ring-cyan-500/20',
    glow: 'group-hover:shadow-[0_0_40px_-12px_rgba(34,211,238,0.3)]',
    highlight: 'text-cyan-400',
  },
  violet: {
    border: 'hover:border-violet-500/40',
    icon: 'text-violet-400',
    tag: 'bg-violet-500/10 text-violet-400 ring-violet-500/20',
    glow: 'group-hover:shadow-[0_0_40px_-12px_rgba(167,139,250,0.3)]',
    highlight: 'text-violet-400',
  },
  fuchsia: {
    border: 'hover:border-fuchsia-500/40',
    icon: 'text-fuchsia-400',
    tag: 'bg-fuchsia-500/10 text-fuchsia-400 ring-fuchsia-500/20',
    glow: 'group-hover:shadow-[0_0_40px_-12px_rgba(232,121,249,0.3)]',
    highlight: 'text-fuchsia-400',
  },
};
---

<section id="diferenciais" class="mx-auto max-w-6xl px-6 py-24">
  <div class="mb-14 text-center">
    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-slate-400">Diferenciais técnicos</p>
    <h2 class="text-3xl font-bold text-white sm:text-4xl">
      Por que trabalhar com a{' '}
      <span class="bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-transparent">Marujos</span>
    </h2>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
    {cards.map((card) => {
      const a = accentMap[card.accent];
      return (
        <div
          id={card.id}
          class={`bento-card group relative flex flex-col gap-5 rounded-2xl border border-slate-800 bg-slate-900/60 p-7 backdrop-blur-sm transition-all duration-500 ${card.span} ${a.border} ${a.glow}`}
        >
          <!-- icon -->
          <div class={`flex h-10 w-10 items-center justify-center rounded-xl bg-slate-800 ${a.icon}`}>
            <Fragment set:html={card.icon} />
          </div>

          <!-- title -->
          <h3 class="text-lg font-semibold text-white">{card.title}</h3>

          <!-- description -->
          <p class="flex-1 text-sm leading-relaxed text-slate-400">{card.description}</p>

          <!-- highlight -->
          {card.highlight && (
            <p class={`text-xs font-medium ${a.highlight}`}>
              ✦ {card.highlight}
            </p>
          )}

          <!-- link -->
          {card.link && (
            <a
              href={card.link.href}
              target="_blank"
              rel="noopener noreferrer"
              class={`text-xs font-semibold transition-opacity duration-200 hover:opacity-80 ${a.icon}`}
            >
              {card.link.label}
            </a>
          )}

          <!-- tags -->
          <div class="flex flex-wrap gap-2">
            {card.tags.map((tag) => (
              <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset ${a.tag}`}>
                {tag}
              </span>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</section>

<style is:global>
  .bento-card {
    opacity: 0;
    transform: translateY(28px) scale(0.94);
  }
  .bento-card.bento-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>

<noscript>
  <style>.bento-card { opacity: 1 !important; transform: none !important; }</style>
</noscript>

<script>
  const section = document.getElementById('diferenciais');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.bento-card'));

  if (section && cards.length) {
    const showCards = () => {
      cards.forEach((card, i) => {
        // Aplica delay escalonado por inline style para não conflitar com
        // o transition-all do hover (que é restaurado após a animação).
        card.style.transition =
          `opacity 500ms cubic-bezier(0.16,1,0.3,1) ${i * 100}ms,` +
          `transform 500ms cubic-bezier(0.16,1,0.3,1) ${i * 100}ms`;
        card.classList.add('bento-visible');
      });
      // Remove os delays inline após a animação para não atrasar efeitos de hover
      setTimeout(() => {
        cards.forEach(card => { card.style.transition = ''; });
      }, 800 + cards.length * 100);
    };

    const io = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        io.disconnect();
        showCards();
      }
    }, { rootMargin: '0px 0px -5% 0px' });

    io.observe(section);

    // Fallback: garante visibilidade após 2.5s caso o observer não dispare
    setTimeout(() => {
      if (parseFloat(getComputedStyle(cards[0]).opacity) < 0.5) showCards();
    }, 2500);
  }
</script>
