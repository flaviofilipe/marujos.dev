---
import Layout         from '../layouts/Layout.astro';
import Header         from '../components/Header.astro';
import Hero           from '../components/Hero.astro';
import BentoGrid      from '../components/BentoGrid.astro';
import ComoTrabalhamos from '../components/sections/ComoTrabalhamos.astro';
import Projetos       from '../components/sections/Projetos.astro';
import Stack          from '../components/sections/Stack.astro';
import Equipe         from '../components/sections/Equipe.astro';
import Depoimentos    from '../components/sections/Depoimentos.astro';
import Clientes       from '../components/sections/Clientes.astro';
import CtaFinal       from '../components/sections/CtaFinal.astro';
---

<Layout
  title="Marujos — Engenharia de software & consultoria tech"
  description="Consultoria de engenharia de software focada em arquitetura serverless, otimização de dados e experiências web de alto impacto."
>
  <a
    href="#conteudo"
    class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-violet-600 focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
  >
    Ir para o conteúdo
  </a>

  {/* ── 1. Header / Navbar ─────────────────────────────────────────────── */}
  <Header />

  <main id="conteudo" class="pt-[72px]">

    {/* ── 2. Hero ──────────────────────────────────────────────────────── */}
    <Hero />

    <div class="mx-auto h-px max-w-6xl bg-gradient-to-r from-transparent via-slate-700/50 to-transparent" aria-hidden="true"></div>

    {/* ── 3. Diferenciais técnicos ─────────────────────────────────────── */}
    <BentoGrid />

    <div class="mx-auto h-px max-w-6xl bg-gradient-to-r from-transparent via-slate-700/50 to-transparent" aria-hidden="true"></div>

    {/* ── 4. Como trabalhamos ──────────────────────────────────────────── */}
    <ComoTrabalhamos />

    <div class="mx-auto h-px max-w-6xl bg-gradient-to-r from-transparent via-slate-700/50 to-transparent" aria-hidden="true"></div>

    {/* ── 5. Projetos & Iniciativas ────────────────────────────────────── */}
    <Projetos />

    <div class="mx-auto h-px max-w-6xl bg-gradient-to-r from-transparent via-slate-700/50 to-transparent" aria-hidden="true"></div>

    {/* ── 6. Stack & Ferramentas ───────────────────────────────────────── */}
    <Stack />

    <div class="mx-auto h-px max-w-6xl bg-gradient-to-r from-transparent via-slate-700/50 to-transparent" aria-hidden="true"></div>

    {/* ── 7. Equipe ────────────────────────────────────────────────────── */}
    <!-- <Equipe /> -->

    <div class="mx-auto h-px max-w-6xl bg-gradient-to-r from-transparent via-slate-700/50 to-transparent" aria-hidden="true"></div>

    {/* ── 8. Depoimentos ───────────────────────────────────────────────── */}
    <!-- <Depoimentos /> -->

    <div class="mx-auto h-px max-w-6xl bg-gradient-to-r from-transparent via-slate-700/50 to-transparent" aria-hidden="true"></div>

    {/* ── 9. Empresas que confiam ──────────────────────────────────────── */}
    <Clientes />

    {/* ── 10. CTA final ────────────────────────────────────────────────── */}
    <CtaFinal />

  </main>

  {/* ── 11. Footer ───────────────────────────────────────────────────── */}
  <footer class="border-t border-slate-800/60 bg-slate-950">
    <div class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-6 py-12 sm:flex-row sm:justify-between">

      <div class="flex flex-col items-center gap-1 sm:items-start">
        <span class="bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-sm font-bold text-transparent">
          Marujos
        </span>
        <span class="text-xs text-slate-400">
          © 2026 Marujos — Consultoria e engenharia de software · marujos.dev
        </span>
      </div>

      <nav aria-label="Links do rodapé" class="flex items-center gap-5">
        <a href="https://github.com/flaviofilipe" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-slate-400 transition-colors duration-200 hover:text-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
        <a href="https://linkedin.com/in/flaviofilipedev" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-slate-400 transition-colors duration-200 hover:text-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://medium.com/marujosx" target="_blank" rel="noopener noreferrer" aria-label="Medium" class="text-slate-400 transition-colors duration-200 hover:text-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/>
          </svg>
        </a>
        <a href="mailto:flaviofilipe.dev@gmail.com?subject=Contato%20—%20Marujos" aria-label="E-mail" class="text-slate-400 transition-colors duration-200 hover:text-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </a>
        <span class="h-4 w-px bg-slate-800" aria-hidden="true"></span>
        <a href="#conteudo" aria-label="Voltar ao topo" class="text-slate-400 transition-colors duration-200 hover:text-slate-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m18 15-6-6-6 6"/>
          </svg>
        </a>
      </nav>
    </div>
  </footer>
</Layout>
